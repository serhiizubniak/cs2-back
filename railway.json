{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "bash -c 'mkdir -p ${DATA_DIR:-data} && chmod 755 ${DATA_DIR:-data} && php -S 0.0.0.0:$PORT router.php'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
